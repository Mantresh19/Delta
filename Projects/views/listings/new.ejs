<% layout("/layouts/boilerplate") %>
<body>
    <div class="row">
        <div class="col-8 offset-2">
        <br><br>
        <h3>Create a new listing</h3>
        <form method="POST" action="/listings" novalidate class="needs-validation">
            <div class="mb-3">
                <label for="title" class="form-label">Title</label>
                <input name="listing[title]" type="text" class="form-control" required>
                <div class="valid-feedback">Title looks good!</div>
                <div class="invalid-feedback">Please enter a title</div>
            </div>
            <div class="mb-3">
                <label for="title" class="form-label">Description</label>
                <textarea name="listing[description]" type="text" class="form-control" required></textarea>
                <div class="valid-feedback">Amazing!</div>
                <div class="invalid-feedback">Please enter description</div>
            </div>
            <div class="mb-3">
                <label for="title" class="form-label">Image Link</label>
                <input name="listing[image]" type="text" class="form-control">
            </div>
            <div class="row">
            <div class="mb-3 col-md-4">
                <label for="title" class="form-label">Price</label>
                <input name="listing[price]" class="form-control" required>
                <div class="invalid-feedback">Please enter a valid price</div>
            </div>
            <div class="mb-3 col-md-8">
                <label for="title" class="form-label">Country</label>
                <input name="listing[country]" type="text" class="form-control" required>
                <div class="valid-feedback">Lovely!</div>
                <div class="invalid-feedback">Please enter a valid country name</div>
            </div>
            </div>
            <div class="mb-3">
                <label for="title" class="form-label">Location</label>
                <input name="listing[location]" placeholder="Enter location" type="text" class="form-control" required>
                <div class="valid-feedback">Amazing location!</div>
                <div class="invalid-feedback">Please enter a valid location</div>
            </div>
            <button class="btn btn-dark add-btn">Add</button>
            <br><br>
        </form>
        </div>
    </div>
</body>